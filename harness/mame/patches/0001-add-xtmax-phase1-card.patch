+// license:BSD-3-Clause
+// copyright-holders:OpenAI
+/***************************************************************************
+
+    XTMax phase-2 model
+
+    This models the XT-visible contract only:
+    - option ROM at 0xCE000
+    - SD streaming window at 0xCE800-0xCEFFF
+    - MMAN register block at 0x260-0x26F
+    - SD register block at 0x280-0x287
+
+    The Teensy firmware is not emulated. Instead, this device models the
+    external behavior the XT sees and optionally backs the SD path with a raw
+    host image specified by the XTMAX_MAME_SD_IMAGE environment variable.
+
+***************************************************************************/
+
+#include "emu.h"
+#include "xtmax.h"
+
+#include "osdcore.h"
+
+#include <algorithm>
+#include <array>
+#include <cstring>
+#include <ios>
+
+
+namespace {
+
+constexpr offs_t XTMAX_ROM_BASE = 0xce000;
+constexpr offs_t XTMAX_ROM_END = XTMAX_ROM_BASE + 0x07ff;
+constexpr offs_t XTMAX_SD_WINDOW_BASE = XTMAX_ROM_END + 1;
+constexpr offs_t XTMAX_SD_WINDOW_END = XTMAX_SD_WINDOW_BASE + 0x07ff;
+constexpr offs_t XTMAX_MMAN_BASE = 0x260;
+constexpr offs_t XTMAX_MMAN_END = XTMAX_MMAN_BASE + 0x0f;
+constexpr offs_t XTMAX_SD_BASE = 0x280;
+constexpr offs_t XTMAX_SD_END = XTMAX_SD_BASE + 0x07;
+
+constexpr uint32_t SD_SECTOR_SIZE = 512;
+constexpr uint8_t SD_R1_IDLE = 0x01;
+constexpr uint8_t SD_R1_READY = 0x00;
+constexpr uint8_t SD_R1_ILLEGAL = 0x04;
+constexpr uint8_t SD_DATA_TOKEN = 0xfe;
+constexpr uint8_t SD_DATA_ACCEPTED = 0x05;
+
+} // anonymous namespace
+
+ROM_START( xtmax )
+	ROM_REGION(0x00800, "bootrom", 0)
+	ROM_LOAD("xtmax_bootrom.bin", 0x000000, 0x000800, CRC(77bcb6cc) SHA1(788bbaab2d49c66bbc62061f5192bdf0de42a3c8))
+ROM_END
+
+DEFINE_DEVICE_TYPE(ISA8_XTMAX, xtmax_device, "xtmax", "XTMax phase-2 adapter")
+
+const tiny_rom_entry *xtmax_device::device_rom_region() const
+{
+	return ROM_NAME( xtmax );
+}
+
+xtmax_device::xtmax_device(const machine_config &mconfig, const char *tag, device_t *owner, uint32_t clock)
+	: device_t(mconfig, ISA8_XTMAX, tag, owner, clock)
+	, device_isa8_card_interface(mconfig, *this)
+	, m_sd_config(0x00)
+	, m_sd_cs(0x01)
+	, m_sd_timeout(0x01)
+	, m_sd_cmd_pos(0)
+	, m_sd_resp_head(0)
+	, m_sd_resp_count(0)
+	, m_sd_write_pos(0)
+	, m_sd_pending_lba(0)
+	, m_sd_selected(false)
+	, m_sd_initialized(false)
+	, m_sd_app_cmd(false)
+	, m_sd_expect_write_token(false)
+	, m_sd_expect_write_data(false)
+{
+}
+
+void xtmax_device::device_start()
+{
+	set_isa_device();
+
+	save_item(NAME(m_mman));
+	save_item(NAME(m_sd_scratch));
+	save_item(NAME(m_sd_config));
+	save_item(NAME(m_sd_cs));
+	save_item(NAME(m_sd_timeout));
+	save_item(NAME(m_sd_cmd));
+	save_item(NAME(m_sd_resp));
+	save_item(NAME(m_sd_write_buffer));
+	save_item(NAME(m_sd_cmd_pos));
+	save_item(NAME(m_sd_resp_head));
+	save_item(NAME(m_sd_resp_count));
+	save_item(NAME(m_sd_write_pos));
+	save_item(NAME(m_sd_pending_lba));
+	save_item(NAME(m_sd_selected));
+	save_item(NAME(m_sd_initialized));
+	save_item(NAME(m_sd_app_cmd));
+	save_item(NAME(m_sd_expect_write_token));
+	save_item(NAME(m_sd_expect_write_data));
+}
+
+void xtmax_device::device_reset()
+{
+	std::fill(std::begin(m_mman), std::end(m_mman), 0xff);
+	std::fill(std::begin(m_sd_scratch), std::end(m_sd_scratch), 0x00);
+	std::fill(std::begin(m_sd_cmd), std::end(m_sd_cmd), 0x00);
+	std::fill(std::begin(m_sd_resp), std::end(m_sd_resp), 0xff);
+	std::fill(std::begin(m_sd_write_buffer), std::end(m_sd_write_buffer), 0x00);
+
+	m_sd_config = 0x00;
+	m_sd_cs = 0x01;
+	m_sd_timeout = 0x01;
+	m_sd_selected = false;
+	m_sd_initialized = false;
+	m_sd_app_cmd = false;
+	m_sd_pending_lba = 0;
+
+	reset_sd_transaction();
+	reopen_sd_image();
+
+	m_isa->install_rom(this, XTMAX_ROM_BASE, XTMAX_ROM_END, "bootrom");
+	m_isa->install_memory(XTMAX_SD_WINDOW_BASE, XTMAX_SD_WINDOW_END, read8sm_delegate(*this, FUNC(xtmax_device::sd_window_r)), write8sm_delegate(*this, FUNC(xtmax_device::sd_window_w)));
+	m_isa->install_device(XTMAX_MMAN_BASE, XTMAX_MMAN_END, read8sm_delegate(*this, FUNC(xtmax_device::mman_r)), write8sm_delegate(*this, FUNC(xtmax_device::mman_w)));
+	m_isa->install_device(XTMAX_SD_BASE, XTMAX_SD_END, read8sm_delegate(*this, FUNC(xtmax_device::sd_r)), write8sm_delegate(*this, FUNC(xtmax_device::sd_w)));
+}
+
+bool xtmax_device::image_ready() const
+{
+	return m_sd_image.is_open();
+}
+
+void xtmax_device::reopen_sd_image()
+{
+	if (m_sd_image.is_open())
+		m_sd_image.close();
+
+	char const *const image_path = osd_getenv("XTMAX_MAME_SD_IMAGE");
+	if (!image_path || !image_path[0])
+		return;
+
+	m_sd_image.open(image_path, std::ios::in | std::ios::out | std::ios::binary);
+	if (!m_sd_image.is_open())
+	{
+		std::ofstream create(image_path, std::ios::binary);
+		create.close();
+		m_sd_image.open(image_path, std::ios::in | std::ios::out | std::ios::binary);
+	}
+
+	if (!m_sd_image.is_open())
+		logerror("xtmax: failed to open SD image '%s'\n", image_path);
+}
+
+void xtmax_device::reset_sd_transaction()
+{
+	m_sd_cmd_pos = 0;
+	m_sd_resp_head = 0;
+	m_sd_resp_count = 0;
+	m_sd_write_pos = 0;
+	m_sd_expect_write_token = false;
+	m_sd_expect_write_data = false;
+}
+
+void xtmax_device::queue_sd_response(uint8_t data)
+{
+	if (m_sd_resp_count >= std::size(m_sd_resp))
+		return;
+
+	uint16_t const tail = (m_sd_resp_head + m_sd_resp_count) % std::size(m_sd_resp);
+	m_sd_resp[tail] = data;
+	++m_sd_resp_count;
+}
+
+void xtmax_device::queue_sd_sector(uint32_t lba)
+{
+	std::array<uint8_t, SD_SECTOR_SIZE> buffer{};
+
+	if (image_ready())
+	{
+		m_sd_image.clear();
+		m_sd_image.seekg(static_cast<std::streamoff>(lba) * SD_SECTOR_SIZE, std::ios::beg);
+		if (m_sd_image.good())
+		{
+			m_sd_image.read(reinterpret_cast<char *>(buffer.data()), buffer.size());
+			if (m_sd_image.bad())
+				m_sd_image.clear();
+		}
+	}
+
+	queue_sd_response(SD_DATA_TOKEN);
+	for (uint8_t byte : buffer)
+		queue_sd_response(byte);
+	queue_sd_response(0xff);
+	queue_sd_response(0xff);
+}
+
+void xtmax_device::commit_sd_sector(uint32_t lba)
+{
+	if (image_ready())
+	{
+		m_sd_image.clear();
+		m_sd_image.seekp(static_cast<std::streamoff>(lba) * SD_SECTOR_SIZE, std::ios::beg);
+		if (m_sd_image.good())
+		{
+			m_sd_image.write(reinterpret_cast<char const *>(m_sd_write_buffer), std::size(m_sd_write_buffer));
+			m_sd_image.flush();
+			if (m_sd_image.bad())
+				m_sd_image.clear();
+		}
+	}
+
+	queue_sd_response(SD_DATA_ACCEPTED);
+	queue_sd_response(0xff);
+}
+
+void xtmax_device::handle_sd_command()
+{
+	uint8_t const command = m_sd_cmd[0] & 0x3f;
+	uint32_t const argument =
+		(uint32_t(m_sd_cmd[1]) << 24) |
+		(uint32_t(m_sd_cmd[2]) << 16) |
+		(uint32_t(m_sd_cmd[3]) << 8) |
+		uint32_t(m_sd_cmd[4]);
+
+	if (!image_ready())
+		return;
+
+	switch (command)
+	{
+	case 0:
+		m_sd_initialized = false;
+		m_sd_app_cmd = false;
+		queue_sd_response(SD_R1_IDLE);
+		break;
+
+	case 1:
+		m_sd_initialized = true;
+		m_sd_app_cmd = false;
+		queue_sd_response(SD_R1_READY);
+		break;
+
+	case 8:
+		queue_sd_response(m_sd_initialized ? SD_R1_READY : SD_R1_IDLE);
+		queue_sd_response(0x00);
+		queue_sd_response(0x00);
+		queue_sd_response(0x01);
+		queue_sd_response(0xaa);
+		break;
+
+	case 16:
+		queue_sd_response(SD_R1_READY);
+		break;
+
+	case 17:
+		if (!m_sd_initialized)
+		{
+			queue_sd_response(SD_R1_IDLE);
+			break;
+		}
+		queue_sd_response(SD_R1_READY);
+		queue_sd_sector(argument);
+		break;
+
+	case 24:
+		if (!m_sd_initialized)
+		{
+			queue_sd_response(SD_R1_IDLE);
+			break;
+		}
+		m_sd_pending_lba = argument;
+		m_sd_expect_write_token = true;
+		m_sd_write_pos = 0;
+		queue_sd_response(SD_R1_READY);
+		break;
+
+	case 55:
+		m_sd_app_cmd = true;
+		queue_sd_response(m_sd_initialized ? SD_R1_READY : SD_R1_IDLE);
+		break;
+
+	case 58:
+		queue_sd_response(m_sd_initialized ? SD_R1_READY : SD_R1_IDLE);
+		queue_sd_response(0x40);
+		queue_sd_response(0x00);
+		queue_sd_response(0x00);
+		queue_sd_response(0x00);
+		break;
+
+	case 41:
+		if (!m_sd_app_cmd)
+		{
+			queue_sd_response(SD_R1_ILLEGAL);
+			break;
+		}
+		m_sd_initialized = true;
+		m_sd_app_cmd = false;
+		queue_sd_response(SD_R1_READY);
+		break;
+
+	default:
+		m_sd_app_cmd = false;
+		queue_sd_response(SD_R1_ILLEGAL);
+		break;
+	}
+}
+
+uint8_t xtmax_device::sd_exchange(uint8_t data)
+{
+	if (!m_sd_selected)
+		return 0xff;
+
+	uint8_t incoming = 0xff;
+	if (m_sd_resp_count)
+	{
+		incoming = m_sd_resp[m_sd_resp_head];
+		m_sd_resp_head = (m_sd_resp_head + 1) % std::size(m_sd_resp);
+		--m_sd_resp_count;
+	}
+
+	if (!image_ready())
+		return incoming;
+
+	if (m_sd_expect_write_data)
+	{
+		if (m_sd_write_pos < std::size(m_sd_write_buffer))
+		{
+			m_sd_write_buffer[m_sd_write_pos++] = data;
+			if (m_sd_write_pos == std::size(m_sd_write_buffer))
+			{
+				m_sd_expect_write_data = false;
+				commit_sd_sector(m_sd_pending_lba);
+			}
+		}
+		return incoming;
+	}
+
+	if (m_sd_expect_write_token)
+	{
+		if (data == SD_DATA_TOKEN)
+		{
+			m_sd_expect_write_token = false;
+			m_sd_expect_write_data = true;
+			m_sd_write_pos = 0;
+		}
+		return incoming;
+	}
+
+	if (!m_sd_cmd_pos)
+	{
+		if ((data & 0xc0) == 0x40)
+		{
+			m_sd_cmd[0] = data;
+			m_sd_cmd_pos = 1;
+		}
+		return incoming;
+	}
+
+	m_sd_cmd[m_sd_cmd_pos++] = data;
+	if (m_sd_cmd_pos == std::size(m_sd_cmd))
+	{
+		m_sd_cmd_pos = 0;
+		handle_sd_command();
+	}
+
+	return incoming;
+}
+
+uint8_t xtmax_device::mman_r(offs_t offset)
+{
+	return m_mman[offset & 0x0f];
+}
+
+void xtmax_device::mman_w(offs_t offset, uint8_t data)
+{
+	m_mman[offset & 0x0f] = data;
+}
+
+uint8_t xtmax_device::sd_window_r(offs_t offset)
+{
+	return sd_exchange(0xff);
+}
+
+void xtmax_device::sd_window_w(offs_t offset, uint8_t data)
+{
+	sd_exchange(data);
+}
+
+uint8_t xtmax_device::sd_r(offs_t offset)
+{
+	switch (offset & 0x07)
+	{
+	case 0x00:
+		return sd_exchange(0xff);
+
+	case 0x01:
+		return m_sd_config;
+
+	case 0x02:
+	case 0x03:
+	case 0x04:
+	case 0x05:
+	case 0x06:
+		return m_sd_scratch[(offset & 0x07) - 0x02];
+
+	case 0x07:
+		return m_sd_timeout;
+	}
+
+	return 0xff;
+}
+
+void xtmax_device::sd_w(offs_t offset, uint8_t data)
+{
+	switch (offset & 0x07)
+	{
+	case 0x00:
+		sd_exchange(data);
+		break;
+
+	case 0x01:
+		m_sd_cs = data & 0x01;
+		if (m_sd_cs)
+		{
+			m_sd_selected = false;
+			reset_sd_transaction();
+		}
+		else
+		{
+			m_sd_selected = true;
+		}
+		break;
+
+	case 0x02:
+	case 0x03:
+	case 0x04:
+	case 0x05:
+	case 0x06:
+		m_sd_scratch[(offset & 0x07) - 0x02] = data;
+		break;
+
+	case 0x07:
+		// The Teensy firmware reports whether the requested timeout has elapsed.
+		// This model completes requests immediately and always reports ready.
+		m_sd_timeout = 0x01;
+		break;
+	}
+}
