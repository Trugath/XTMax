@@ -0,0 +1,62 @@
+// license:BSD-3-Clause
+// copyright-holders:OpenAI
+#ifndef MAME_BUS_ISA_XTMAX_H
+#define MAME_BUS_ISA_XTMAX_H
+
+#pragma once
+
+#include "isa.h"
+
+#include <fstream>
+
+class xtmax_device : public device_t, public device_isa8_card_interface
+{
+public:
+	xtmax_device(const machine_config &mconfig, const char *tag, device_t *owner, uint32_t clock);
+
+	uint8_t mman_r(offs_t offset);
+	void mman_w(offs_t offset, uint8_t data);
+	uint8_t sd_window_r(offs_t offset);
+	void sd_window_w(offs_t offset, uint8_t data);
+	uint8_t sd_r(offs_t offset);
+	void sd_w(offs_t offset, uint8_t data);
+
+protected:
+	virtual void device_start() override;
+	virtual void device_reset() override;
+	virtual const tiny_rom_entry *device_rom_region() const override;
+
+private:
+	void reopen_sd_image();
+	void reset_sd_transaction();
+	uint8_t sd_exchange(uint8_t data);
+	void queue_sd_response(uint8_t data);
+	void queue_sd_sector(uint32_t lba);
+	void commit_sd_sector(uint32_t lba);
+	void handle_sd_command();
+	bool image_ready() const;
+
+	uint8_t m_mman[0x10];
+	uint8_t m_sd_scratch[5];
+	uint8_t m_sd_config;
+	uint8_t m_sd_cs;
+	uint8_t m_sd_timeout;
+	uint8_t m_sd_cmd[6];
+	uint8_t m_sd_resp[1024];
+	uint8_t m_sd_write_buffer[512];
+	uint16_t m_sd_cmd_pos;
+	uint16_t m_sd_resp_head;
+	uint16_t m_sd_resp_count;
+	uint16_t m_sd_write_pos;
+	uint32_t m_sd_pending_lba;
+	bool m_sd_selected;
+	bool m_sd_initialized;
+	bool m_sd_app_cmd;
+	bool m_sd_expect_write_token;
+	bool m_sd_expect_write_data;
+	std::fstream m_sd_image;
+};
+
+DECLARE_DEVICE_TYPE(ISA8_XTMAX, xtmax_device)
+
+#endif // MAME_BUS_ISA_XTMAX_H
